{
  "name": "@mwguerra/anonymize",
  "version": "1.0.0",
  "description": "CLI para anonimização determinística de dados pessoais em arquivos XLS, XLSX e CSV",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "anonymize": "./dist/index.js"
  },
  "files": [
    "dist",
    ".anonymizerc.default.json"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "anonymize",
    "lgpd",
    "gdpr",
    "faker",
    "csv",
    "xlsx",
    "cli",
    "data-privacy"
  ],
  "author": "Marcelo Guerra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mwguerra/anonymize.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "chalk": "^5.6.2",
    "chardet": "^2.1.1",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "inquirer": "^13.3.0",
    "papaparse": "^5.5.3",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.3.2",
    "@types/papaparse": "^5.5.2",
    "eslint": "^9.39.3",
    "jiti": "^2.6.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
